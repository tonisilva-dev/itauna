# ═════════════════════════════════════════════════════════════════════════════════
# Supabase Configuration
# ═════════════════════════════════════════════════════════════════════════════════

# URL do projeto Supabase (public)
VITE_SUPABASE_URL=https://vxrfhzfnjcpzwcvtkmhi.supabase.co

# Chave anônima do Supabase (public, para uso no frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave de serviço do Supabase (CONFIDENCIAL, para scripts backend)
# Use esta para bypass de RLS durante sincronização
# Obtenha em: https://app.supabase.com → Project Settings → API Keys
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ═════════════════════════════════════════════════════════════════════════════════
# Sincronização
# ═════════════════════════════════════════════════════════════════════════════════

# Diretório dos rateios mensais (relativo a este script)
RATEIOS_DIR=../../documentos/rateiosMensais

# Log file
LOG_FILE=./sync-rateios.log

# ═════════════════════════════════════════════════════════════════════════════════
# Comportamento
# ═════════════════════════════════════════════════════════════════════════════════

# Se true, ignora duplicatas e sempre sincroniza
# Se false, pula arquivos já sincronizados
SKIP_DUPLICATES=true

# Usuário "criador" padrão para registros (admin ID no Supabase)
DEFAULT_CREATED_BY=00000000-0000-0000-0000-000000000000
